---
interface Props {
  title: string;
  subtitle: string;
  desc?: string;
  date?: string;
}

const { title, subtitle, desc, date } = Astro.props;
---

<div class="flex timeline-entry">
  <div class="education__time">
    <span class="w-4 h-4 time-line-bg block rounded-full mt-1 flex-shrink-0"></span>
    <span class="education__line time-line-bg block h-full w-[2px] translate-x-[7px]"></span>
  </div>
  <div class="experience__data bd-grid px-5 pb-5 w-full">
    <div class="flex items-start justify-between gap-3 flex-wrap mb-1">
      <h3 class="font-semibold">{title}</h3>
      {date && (
        <span class="timeline-date-badge flex-shrink-0">{date}</span>
      )}
    </div>
    <span class="font-light text-sm block mb-2">{subtitle}</span>
    {desc && (
      <p class="my-2 text-justify">{desc}</p>
    )}
  </div>
</div>
